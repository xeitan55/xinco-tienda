// firestore.rules
// Reglas de seguridad de Firestore para XINCO
//
// Para aplicar:
//   Firebase Console → Firestore → Rules → pegar esto → Publicar
// O con Firebase CLI:
//   firebase deploy --only firestore:rules

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Funciones helpers ──────────────────────────────────────
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      // Reemplazá con tu email real de admin
      return isAuthenticated() && request.auth.token.email == 'admin@xinco.com';
    }

    function isOwner(uid) {
      return isAuthenticated() && request.auth.uid == uid;
    }

    // ── Productos: lectura pública, escritura solo admin ───────
    match /products/{productId} {
      allow read:  if true;           // cualquiera puede ver productos
      allow write: if isAdmin();      // solo admin puede crear/editar/borrar
    }

    // ── Pedidos: usuario ve los suyos, admin ve todos ──────────
    match /orders/{orderId} {
      // Crear pedido: cualquier usuario autenticado (al comprar)
      allow create: if isAuthenticated()
                    && request.resource.data.email == request.auth.token.email;

      // Leer pedido: solo si es tuyo o sos admin
      allow read:   if isAdmin()
                    || (isAuthenticated()
                        && resource.data.email == request.auth.token.email);

      // Actualizar/borrar: solo admin
      allow update, delete: if isAdmin();
    }

    // ── Datos de usuario: solo el propio usuario y admin ──────
    match /users/{userId} {
      allow read, write: if isOwner(userId) || isAdmin();
    }

    // ── Config pública (banners): lectura libre, escritura admin
    match /config/banners {
      allow read:  if true;           // todos ven los banners
      allow write: if isAdmin();
    }

    // ── Config de Mercado Pago: SOLO admin, nunca usuarios ────
    // El accessToken está aquí pero las reglas impiden que usuarios lo lean.
    // Aun así, lo ideal es migrar el AT a variables de entorno de Vercel
    // y NO guardarlo en Firestore en absoluto (ver api/create-payment.js)
    match /config/mercadopago {
      allow read, write: if isAdmin();
      // ↑ usuarios regulares NUNCA pueden leer esta colección
    }

    // ── Tracking: lectura pública (para que el cliente rastree),
    //    escritura solo admin ────────────────────────────────────
    match /tracking/{trackId} {
      allow read:  if true;
      allow write: if isAdmin();
    }

    // ── Todo lo demás: denegado por defecto ──────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
