{
  "version": 2,
  "framework": "vite",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "installCommand": "npm install",
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/$1"
    }
  ],
  "rewrites": [
    {
      "source": "/verify",
      "destination": "/verify.html"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
